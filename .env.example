# =============================================================================
# Job Ops - Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

MODEL=google/gemini-3-flash-preview

# Optional: Authentication for protected app and API access
# The app is fully unauthenticated if this isn't set, which is the default.
# Both values can also be managed from the Settings UI (stored in the DB).
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=

# Optional override of the JWT session-signing secret (at least 32 characters).
# If omitted, Job Ops manages one in the database (runtime_secrets), so a DB
# snapshot restore keeps sessions working. Set this only to pin the secret
# externally; the env value wins over the DB one.
# JWT_SECRET=

# Optional baseline for JWT session expiry in seconds (default: 86400 = 24h).
# The "Session expiry" value in the Settings UI overrides this.
# JWT_EXPIRY_SECONDS=86400

# =============================================================================
# JobSpy - Job search configuration
# =============================================================================
# Filter for remote-only jobs (default: 0 = disabled)
# JOBSPY_IS_REMOTE=0
